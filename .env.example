# Token de ton bot Discord (depuis https://discord.com/developers/applications)
DISCORD_TOKEN=ton_token_ici

# ID du salon où le bot Wordle poste les résultats (clic droit sur le salon > Copier l'ID)
WORDLE_CHANNEL_ID=123456789012345678

# ID du salon où ton bot doit poster les classements hebdomadaires
LEADERBOARD_CHANNEL_ID=123456789012345678

# Nom exact du bot Wordle tel qu'il apparaît sur Discord (défaut: "Wordle")
WORDLE_BOT_NAME=Wordle

# Jour de la semaine pour le classement auto: 0=Lundi, 1=Mardi, ... 6=Dimanche (défaut: 0)
LEADERBOARD_WEEKDAY=0

# Heure UTC à laquelle poster le classement (défaut: 8 = 08h00 UTC)
LEADERBOARD_HOUR=8
